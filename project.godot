config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Manta Plataforma Movil"
run/main_scene="res://modulos/menu_principal/escenas/menu_principal/menu_principal.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility", "Mobile")
